#include <iostream>
#include <vector>
#include <queue>
using namespace std;

int dir[4][2] = { {-1,0},{1,0},{0,-1},{0,1} };
int N, M;
vector<vector<int>> lab;

int virusCnt = 0;
int spaceCnt = 0;
vector<pair<int, int>> virusPos;
vector<bool> activate;

int res = 1e9;

void dfs(int cnt, int idx) {
	if (cnt == M) {
		vector<vector<bool>> visited(N, vector<bool>(N, false));
		queue<pair<int, int>> q;
		for (int i = 0; i < virusCnt; i++) {
			if (activate[i]) {
				int r = virusPos[i].first;
				int c = virusPos[i].second;
				visited[r][c] = true;
				q.push(virusPos[i]);
			}
		}

		int sec = 0;
		int visitedCnt = 0;

		while (!q.empty()) {
			if (visitedCnt >= spaceCnt) break;

			int sz = q.size();

			while (sz--) {
				int currR = q.front().first;
				int currC = q.front().second;
				q.pop();

				for (int i = 0; i < 4; i++) {
					int nextR = currR + dir[i][0];
					int nextC = currC + dir[i][1];

					if (nextR < 0 || nextR >= N || nextC < 0 || nextC >= N) continue;

					// 이미 방문했거나 벽인 경우
					if (visited[nextR][nextC] || lab[nextR][nextC] == 1) continue;

					visited[nextR][nextC] = true;
					if (lab[nextR][nextC] == 0) visitedCnt++;
					q.push({ nextR,nextC });
				}
			}

			sec++;
		}

		

		if (visitedCnt == spaceCnt) {
			if (sec < res) res = sec;
		}

		return;
	}

	if (idx == virusCnt) return;

	activate[idx] = true;
	dfs(cnt + 1, idx + 1);
	activate[idx] = false;
	dfs(cnt, idx + 1);
}

int main() {
	cin >> N >> M;

	lab.assign(N, vector<int>(N, 0));

	for (int i = 0; i < N; i++) {
		for (int j = 0; j < N; j++) {
			int n; cin >> n;
			lab[i][j] = n;

			if (n == 2) {
				virusCnt++;
				virusPos.push_back({ i,j });
			}

			if (n == 0) spaceCnt++;
		}
	}

	activate.assign(virusCnt, false);

	dfs(0, 0);

	if (res == 1e9) cout << -1;
	else cout << res;
}
