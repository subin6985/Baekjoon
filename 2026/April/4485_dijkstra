#include <iostream>
#include <vector>
#include <queue>
using namespace std;

int dir[4][2] = { {0,1},{0,-1},{1,0},{-1,0} };
int INF = 1e9;

int main() {
	ios::sync_with_stdio(false);
	cin.tie(NULL);
	cout.tie(NULL);

	int N; cin >> N;

	int turn = 1;
	while (N > 0) {
		// 2차원 배열을 1차원 배열로 다루기
		vector<pair<int, int>> graph[125 * 125];
		int first;
		for (int i = 0; i < N; i++) {
			for (int j = 0; j < N; j++) {
				int n; cin >> n;

				if (i == 0 && j == 0) first = n;

				int to = i * N + j;
				for (int k = 0; k < 4; k++) {
					int newR = i + dir[k][0];
					int newC = j + dir[k][1];
					if (newR < 0 || newR >= N || newC < 0 || newC >= N) continue;
					
					int from = newR * N + newC;
					graph[from].push_back({ to,n });
				}
			}
		}

		vector<int> dist(N * N, INF);
		priority_queue<pair<int, int>, vector<pair<int, int>>, greater<>> pq;

		dist[0] = first;
		pq.push({ first,0 });

		while (!pq.empty()) {
			int currCost = pq.top().first;
			int currCity = pq.top().second;
			pq.pop();

			if (dist[currCity] < currCost) continue;

			for (int i = 0; i < graph[currCity].size(); i++) {
				int nextCity = graph[currCity][i].first;
				int nextCost = graph[currCity][i].second;

				if (nextCost + currCost < dist[nextCity]) {
					dist[nextCity] = nextCost + currCost;
					pq.push({ dist[nextCity], nextCity });
				}
			}
		}

		cout << "Problem " << turn << ": " << dist[N * N - 1] << "\n";

		cin >> N;
		turn++;
	}
}
